{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "ConnectionStrings": {
    "DefaultConnection": "Host=YOUR_HOST_HERE;Database=YOUR_DB_HERE;Username=YOUR_USER;Password=YOUR_PASSWORD;SSL Mode=Require;"
  },
  "JwtSettings": {
    "Secret": "SuperSecretKeyThatIsAtLeast32CharactersLong!",
    "Issuer": "IPRS.Server",
    "Audience": "IPRS.Client",
    "ExpiryInMinutes": 60
  },
  "MaintenanceMode": {
    "IsEnabled": false
  }
}
